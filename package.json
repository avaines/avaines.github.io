{
  "name": "avaines.github.io",
  "version": "1.0.0",
  "description": "Vaines.org Portal Site",
  "main": "index.js",
  "repository": "https://github.com/avaines/avaines.github.io",
  "author": "Aiden Vaines",
  "license": "MIT",
  "scripts": {
    "start": "hugo server --disableFastRender",
    "build": "NODE_ENV=production hugo --gc",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:unit": "jest scripts/syndication",
    "test:syndication": "jest scripts/syndication --coverage",
    "syndicate": "node scripts/syndication/index.js",
    "syndicate:dry-run": "SYNDICATION_DRY_RUN=true node scripts/syndication/index.js",
    "syndicate:disable": "npm pkg set syndication.enabled=false",
    "syndicate:enable": "npm pkg set syndication.enabled=true"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^4.0.3",
    "@tailwindcss/typography": "^0.4.0",
    "autoprefixer": "^10.2.5",
    "postcss-cli": "^8.3.1",
    "postcss-import": "^14.0.1",
    "tailwindcss": "^2.1.1",
    "@atproto/api": "^0.12.0",
    "axios": "^1.6.0",
    "gray-matter": "^4.0.3",
    "mastodon-api": "^1.3.0",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "twitter-api-v2": "^1.15.0",
    "unified": "^11.0.4"
  },
  "browserslist": [
    "last 1 version",
    "> 1%",
    "maintained node versions",
    "not dead"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.17",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "postcss": "^8.4.14"
  },
  "syndication": {
    "enabled": true,
    "baseUrl": "https://www.vaines.org",
    "targets": {
      "bluesky": {
        "enabled": true
      },
      "devto": {
        "enabled": true
      },
      "hashnode": {
        "enabled": true
      },
      "mastodon": {
        "enabled": true
      },
      "medium": {
        "enabled": true
      },
      "substack": {
        "enabled": true
      },
      "twitter": {
        "enabled": true
      }
    },
    "defaults": {
      "delay": 0,
      "canonicalNote": "Originally published at {{url}}",
      "maxRetries": 3,
      "retryDelay": 5000
    }
  }
}
