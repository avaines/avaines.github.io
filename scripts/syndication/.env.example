# Syndication Environment Variables
# Copy this file to .env for local testing

# Dry run mode - set to 'true' to test without actually posting
SYNDICATION_DRY_RUN=true

# Global enable/disable (overrides package.json)
# SYNDICATION_ENABLED=true

# dev.to
# Get your key from: https://dev.to/settings/extensions
DEVTO_API_KEY=

# Hashnode
# Get your token from: https://hashnode.com/settings/developer
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Twitter/X
# Create app at: https://developer.twitter.com/en/portal/dashboard
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Bluesky
# Use your Bluesky handle and password
BLUESKY_HANDLE=
BLUESKY_PASSWORD=

# Mastodon
# Generate token in your instance settings > Development > New Application
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE=mastodon.social

# Substack (optional)
# Set SUBSTACK_TOKEN to your `substack.sid` cookie value
# Set SUBSTACK_PUBLICATION_URL to your publication hostname (e.g. mypub.substack.com)
SUBSTACK_TOKEN=
SUBSTACK_PUBLICATION_URL=

# Legacy names (still supported for backward compatibility)
# SUBSTACK_API_KEY=
# SUBSTACK_PUBLICATION_ID=

# Lobste.rs
# Use your Lobste.rs username and password
LOBSTERS_USERNAME=
LOBSTERS_PASSWORD=
